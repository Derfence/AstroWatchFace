                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <ComplicationSlot
            x="55"
            y="55"
            width="340"
            height="340"
            slotId="2"
            displayName="@string/slot_celestial_inner_name"
            supportedTypes="RANGED_VALUE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="340" height="340" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.CelestialInnerMotionDataSourceService"
                primaryProviderType="RANGED_VALUE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="340" height="340" pivotX="0.5" pivotY="0.5" name="SunMotion">
                    <Transform target="angle" value="0.2 * (floor([COMPLICATION.RANGED_VALUE_MIN] / 2048) + (([COMPLICATION.RANGED_VALUE_MIN] % 2048) - 900) * (([MINUTE] % 10) / 10.0))" />
                    <PartImage x="57" y="56" width="117" height="133" name="SunTail">
                        <Image resource="celestial_sun_tail" />
                    </PartImage>
                    <PartImage x="159" y="49" width="22" height="22" pivotX="0.5" pivotY="0.5" name="SunIcon">
                        <Image resource="celestial_sun_icon" />
                        <Transform target="angle" value="-0.2 * (floor([COMPLICATION.RANGED_VALUE_MIN] / 2048) + (([COMPLICATION.RANGED_VALUE_MIN] % 2048) - 900) * (([MINUTE] % 10) / 10.0))" />
                    </PartImage>
                </Group>
                <Group x="0" y="0" width="340" height="340" pivotX="0.5" pivotY="0.5" name="MoonMotion">
                    <Transform target="angle" value="0.2 * (floor(([COMPLICATION.RANGED_VALUE_VALUE] - 4194304) / 2048) + ((([COMPLICATION.RANGED_VALUE_VALUE] - 4194304) % 2048) - 900) * (([MINUTE] % 10) / 10.0))" />
                    <PartImage x="52" y="51" width="122" height="138" name="MoonTail">
                        <Image resource="celestial_moon_tail" />
                    </PartImage>
                    <PartImage x="159" y="44" width="22" height="22" pivotX="0.5" pivotY="0.5" name="MoonIcon">
                        <Image resource="celestial_moon_icon" />
                        <Transform target="angle" value="-0.2 * (floor(([COMPLICATION.RANGED_VALUE_VALUE] - 4194304) / 2048) + ((([COMPLICATION.RANGED_VALUE_VALUE] - 4194304) % 2048) - 900) * (([MINUTE] % 10) / 10.0))" />
                    </PartImage>
                </Group>
                <Group x="0" y="0" width="340" height="340" pivotX="0.5" pivotY="0.5" name="MercuryMotion">
                    <Transform target="angle" value="0.2 * (floor(([COMPLICATION.RANGED_VALUE_MAX] - 8388608) / 2048) + ((([COMPLICATION.RANGED_VALUE_MAX] - 8388608) % 2048) - 900) * (([MINUTE] % 10) / 10.0))" />
                    <PartImage x="47" y="46" width="127" height="144" name="MercuryTail">
                        <Image resource="celestial_mercury_tail" />
                    </PartImage>
                    <PartImage x="159" y="39" width="22" height="22" pivotX="0.5" pivotY="0.5" name="MercuryIcon">
                        <Image resource="celestial_mercury_icon" />
                        <Transform target="angle" value="-0.2 * (floor(([COMPLICATION.RANGED_VALUE_MAX] - 8388608) / 2048) + ((([COMPLICATION.RANGED_VALUE_MAX] - 8388608) % 2048) - 900) * (([MINUTE] % 10) / 10.0))" />
                    </PartImage>
                </Group>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <ComplicationSlot
            x="55"
            y="55"
            width="340"
            height="340"
            slotId="3"
