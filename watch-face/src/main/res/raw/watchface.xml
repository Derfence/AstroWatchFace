<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Scene>
        <PartDraw x="0" y="0" width="450" height="450" name="BlackBackground">
            <Rectangle x="0" y="0" width="450" height="450">
                <Fill color="#ff000000" />
            </Rectangle>
        </PartDraw>

        <ComplicationSlot
            x="0"
            y="0"
            width="450"
            height="450"
            slotId="6"
            displayName="@string/slot_constellation_background_name"
            supportedTypes="PHOTO_IMAGE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="450" height="450" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.ConstellationBackgroundDataSourceService"
                primaryProviderType="PHOTO_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="PHOTO_IMAGE">
                <PartImage x="0" y="0" width="450" height="450" name="ConstellationBackgroundImage">
                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <ComplicationSlot
            x="0"
            y="0"
            width="450"
            height="450"
            slotId="1"
            displayName="@string/slot_24h_name"
            supportedTypes="PHOTO_IMAGE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="450" height="450" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.Dial24hDataSourceService"
                primaryProviderType="PHOTO_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="PHOTO_IMAGE">
                <PartImage x="0" y="0" width="450" height="450" name="Dial24hImage">
                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <PartImage
            x="219"
            y="3"
            width="12"
            height="222"
            pivotX="0.5"
            pivotY="1.0"
            name="NowSeparator">
            <Image resource="now_separator" />
            <Transform target="angle" value="[HOUR_0_23_MINUTE] * 15" />
        </PartImage>

        <ComplicationSlot
            x="55"
            y="55"
            width="340"
            height="340"
            slotId="7"
            displayName="@string/slot_celestial_horizon_name"
            supportedTypes="PHOTO_IMAGE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="340" height="340" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.CelestialHorizonDataSourceService"
                primaryProviderType="PHOTO_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="PHOTO_IMAGE">
                <PartImage x="0" y="0" width="340" height="340" name="CelestialHorizonImage">
                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <ComplicationSlot
            x="55"
            y="55"
            width="340"
            height="340"
            slotId="2"
            displayName="@string/slot_celestial_overlay_name"
            supportedTypes="PHOTO_IMAGE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="340" height="340" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.CelestialOverlayDataSourceService"
                primaryProviderType="PHOTO_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="PHOTO_IMAGE">
                <PartImage x="0" y="0" width="340" height="340" name="CelestialOverlayImage">
                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <ComplicationSlot
            x="125"
            y="120"
            width="200"
            height="190"
            slotId="4"
            displayName="@string/slot_status_overlay_name"
            supportedTypes="PHOTO_IMAGE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="200" height="190" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.StatusOverlayDataSourceService"
                primaryProviderType="PHOTO_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="PHOTO_IMAGE">
                <PartImage x="0" y="0" width="200" height="190" name="StatusOverlayImage">
                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <PartImage
            x="216"
            y="89"
            width="18"
            height="140"
            pivotX="0.5"
            pivotY="0.97"
            name="Hour24hHand">
            <Image resource="hour_hand_bitmap" />
            <Transform target="angle" value="[HOUR_0_23_MINUTE] * 15" />
        </PartImage>

        <AnalogClock x="0" y="0" width="450" height="450">
            <MinuteHand
                resource="minute_hand"
                x="218"
                y="60"
                width="14"
                height="170"
                pivotX="0.5"
                pivotY="0.97" />
            <SecondHand
                resource="second_hand"
                x="222"
                y="45"
                width="6"
                height="190"
                pivotX="0.5"
                pivotY="0.95">
                <Tick duration="0.05" strength="1.0" />
            </SecondHand>
        </AnalogClock>

        <PartImage x="207" y="207" width="36" height="36" name="CenterCap">
            <Image resource="center_cap" />
        </PartImage>

        <PartDraw x="0" y="0" width="450" height="450" name="BatteryOutline">
            <Rectangle x="213" y="37" width="24" height="1.4">
                <Fill color="#fff5f5f2" />
            </Rectangle>
            <Rectangle x="213" y="47.6" width="24" height="1.4">
                <Fill color="#fff5f5f2" />
            </Rectangle>
            <Rectangle x="213" y="37" width="1.4" height="12">
                <Fill color="#fff5f5f2" />
            </Rectangle>
            <Rectangle x="235.6" y="37" width="1.4" height="12">
                <Fill color="#fff5f5f2" />
            </Rectangle>
            <Rectangle x="238" y="41" width="3" height="4">
                <Fill color="#fff5f5f2" />
            </Rectangle>
        </PartDraw>

        <Condition>
            <Expressions>
                <Expression name="BatteryLow"><![CDATA[[BATTERY_PERCENT] <= 20]]></Expression>
                <Expression name="BatteryWarning"><![CDATA[[BATTERY_PERCENT] <= 30]]></Expression>
                <Expression name="BatteryHigh"><![CDATA[[BATTERY_PERCENT] > 80]]></Expression>
            </Expressions>
            <Compare expression="BatteryLow">
                <PartDraw x="0" y="0" width="450" height="450" name="BatteryFillLow">
                    <Rectangle x="215" y="39" width="20" height="8">
                        <Fill color="#ffe53935" />
                        <Transform target="width" value="20.0 * [BATTERY_PERCENT] / 100.0" />
                    </Rectangle>
                </PartDraw>
            </Compare>
            <Compare expression="BatteryWarning">
                <PartDraw x="0" y="0" width="450" height="450" name="BatteryFillWarning">
                    <Rectangle x="215" y="39" width="20" height="8">
                        <Fill color="#ffff952a" />
                        <Transform target="width" value="20.0 * [BATTERY_PERCENT] / 100.0" />
                    </Rectangle>
                </PartDraw>
            </Compare>
            <Compare expression="BatteryHigh">
                <PartDraw x="0" y="0" width="450" height="450" name="BatteryFillHigh">
                    <Rectangle x="215" y="39" width="20" height="8">
                        <Fill color="#ff40d270" />
                        <Transform target="width" value="20.0 * [BATTERY_PERCENT] / 100.0" />
                    </Rectangle>
                </PartDraw>
            </Compare>
            <Default>
                <PartDraw x="0" y="0" width="450" height="450" name="BatteryFillDefault">
                    <Rectangle x="215" y="39" width="20" height="8">
                        <Fill color="#fff5f5f2" />
                        <Transform target="width" value="20.0 * [BATTERY_PERCENT] / 100.0" />
                    </Rectangle>
                </PartDraw>
            </Default>
        </Condition>

        <ComplicationSlot
            x="0"
            y="0"
            width="450"
            height="450"
            slotId="5"
            displayName="@string/slot_mode_overlay_name"
            supportedTypes="PHOTO_IMAGE EMPTY"
            isCustomizable="FALSE">
            <BoundingOval x="0" y="0" width="450" height="450" />
            <DefaultProviderPolicy
                primaryProvider="com.derfence.astroface.wear/com.derfence.astroface.wear.complication.ModeOverlayDataSourceService"
                primaryProviderType="PHOTO_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY" />
            <Complication type="PHOTO_IMAGE">
                <PartImage x="0" y="0" width="450" height="450" name="ModeOverlayImage">
                    <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                </PartImage>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <PartDraw x="175" y="175" width="100" height="100" name="ModeTapTarget">
            <Rectangle x="0" y="0" width="100" height="100">
                <Fill color="#01000000" />
            </Rectangle>
            <Launch target="com.derfence.astroface.wear/com.derfence.astroface.wear.ModeCycleActivity" />
        </PartDraw>
    </Scene>
</WatchFace>
